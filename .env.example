# Primary LLM settings
EMPLOYMENT_API_KEY=
EMPLOYMENT_BASE_URL=https://api.openai.com/v1
EMPLOYMENT_MODEL_NAME=gpt-4o-mini
EMPLOYMENT_TIMEOUT_SECONDS=120

# Report output
EMPLOYMENT_REPORT_DIR=reports

# Search settings
EMPLOYMENT_SEARCH_API_KEY=
EMPLOYMENT_SEARCH_PROVIDER=tavily
EMPLOYMENT_SEARCH_TIMEOUT_SECONDS=30
EMPLOYMENT_MAX_SEARCH_RESULTS=8

